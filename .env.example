# Обязательно: ключ OpenRouter (https://openrouter.ai/settings/keys), начинается с sk-or-...
OPENROUTER_API_KEY=вставьте_сюда_ключ

# Необязательно: модель (по умолчанию Nano Banana 2)
OPENROUTER_MODEL=google/gemini-3.1-flash-image-preview

# Необязательно: ориентир стоимости одной картинки в $ — для подсчёта "≈ N генераций"
EST_COST_PER_IMAGE=0.07

# Необязательно: простой общий пароль для входа сотрудников (заголовок x-access-password)
ACCESS_PASSWORD=

# Необязательно: адрес приложения (для заголовка HTTP-Referer в OpenRouter)
APP_URL=

# Необязательно: порт (по умолчанию 3000)
PORT=3000
